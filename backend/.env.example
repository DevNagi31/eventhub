# Server
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/eventhub

# Redis (required for BullMQ job queue + caching)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production

# APIs
TICKETMASTER_API_KEY=your_ticketmaster_api_key
SEATGEEK_CLIENT_ID=your_seatgeek_client_id
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret
PANDASCORE_API_KEY=your_pandascore_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Scraper Configuration
SCRAPER_ENABLED=true
SCRAPE_DEFAULT_LAT=42.0987
SCRAPE_DEFAULT_LNG=-75.9179
SCRAPE_RADIUS=100
SCRAPE_CRON_SCHEDULE=0 */4 * * *
SCRAPE_EVENTBRITE_LOCATION_SLUG=binghamton--ny
SCRAPE_UNIVERSITY_URLS=https://events.binghamton.edu
SCRAPE_COMMUNITY_URLS=

# iCal/ICS Feed URLs (comma-separated)
# Examples: university calendars, venue feeds, Google Calendar public URLs
ICAL_FEED_URLS=
